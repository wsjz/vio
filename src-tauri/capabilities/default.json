{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default"
  ],
  "commands": {
    "allow": [
      "get_system_info",
      "get_system_metrics",
      "get_processes",
      "execute_command",
      "execute_shell",
      "list_directory",
      "read_file",
      "get_home_directory",
      "write_file",
      "get_system_logs",
      "save_layout",
      "load_layout",
      "list_layouts",
      "delete_layout",
      "export_layout",
      "import_layout",
      "get_layouts_directory"
    ]
  }
}
